// FlowCRM AI — core schema
// Multi-tenant: every business table is scoped by organizationId.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  ORG_OWNER
  SALES_MANAGER
  SALES_REP
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum DealStage {
  NEW
  CONTACTED
  QUALIFIED
  MEETING
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ActivityType {
  LEAD_CREATED
  EMAIL_SENT
  CALL_LOGGED
  MEETING_SCHEDULED
  DEAL_STAGE_CHANGED
  NOTE_ADDED
  TASK_COMPLETED
  AI_LEAD_SCORED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  contacts    Contact[]
  companies   Company[]
  leads       Lead[]
  deals       Deal[]
  tasks       Task[]
  activities  Activity[]

  @@index([slug])
}

// A User can belong to multiple orgs (e.g. an agency managing several clients)
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique // Clerk auth identity
  email     String   @unique
  fullName  String
  avatarUrl String?
  createdAt DateTime @default(now())

  memberships   Membership[]
  assignedLeads Lead[]       @relation("LeadAssignee")
  assignedDeals Deal[]       @relation("DealAssignee")
  contactsOwned Contact[]    @relation("ContactOwner")
  tasks         Task[]
  activities    Activity[]

  @@index([email])
}

model Membership {
  id             String   @id @default(cuid())
  role           Role
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
}

model Company {
  id             String   @id @default(cuid())
  name           String
  domain         String?
  industry       String?
  website        String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  deals        Deal[]

  @@index([organizationId])
  @@index([organizationId, name])
}

model Contact {
  id             String   @id @default(cuid())
  fullName       String
  email          String?
  phone          String?
  title          String?
  organizationId String
  companyId      String?
  ownerId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner        User?        @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  leads        Lead[]
  deals        Deal[]
  tasks        Task[]

  // Nulls are exempt from uniqueness in Postgres, so contacts without an
  // email are unaffected — this only blocks true duplicate-email submissions.
  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([organizationId, companyId])
}

model Lead {
  id             String     @id @default(cuid())
  status         LeadStatus @default(NEW)
  source         String? // e.g. "Website Form", "Referral"
  notes          String? // free-text context — budget, timeline, anything a rep
  // typed in; this is what AI scoring reads once that's built
  score          Int        @default(0) // AI qualification score 0-100
  organizationId String
  contactId      String?
  assigneeId     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee     User?        @relation("LeadAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tasks        Task[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model Deal {
  id             String    @id @default(cuid())
  title          String
  value          Decimal   @db.Decimal(12, 2)
  stage          DealStage @default(NEW)
  organizationId String
  companyId      String?
  contactId      String?
  assigneeId     String?
  closedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignee     User?        @relation("DealAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  tasks        Task[]

  // Composite index powers "revenue this month by org" and "pipeline by stage" queries
  @@index([organizationId, stage])
  @@index([organizationId, closedAt])
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  completedAt    DateTime?
  organizationId String
  assigneeId     String?
  contactId      String?
  dealId         String?
  leadId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  contact      Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal         Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Powers both the Tasks list (assignee/org scoping + due-date sort) and
  // the Calendar view (range query on dueAt).
  @@index([organizationId, dueAt])
  @@index([organizationId, completedAt])
}

model Activity {
  id             String       @id @default(cuid())
  type           ActivityType
  message        String
  organizationId String
  actorId        String?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  // Powers the "Recent Activities" feed — always queried newest-first per org
  @@index([organizationId, createdAt])
}

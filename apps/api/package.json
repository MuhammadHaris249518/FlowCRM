{
  "name": "@flowcrm/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate --schema src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/prisma/schema.prisma",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "express": "^4.19.0",
    "@prisma/client": "^5.17.0",
    "zod": "^3.23.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "@clerk/express": "^1.1.0",
    "svix": "^1.24.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "prisma": "^5.17.0",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/node": "^20.14.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.1",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11"
  }
}
